@echo off
setlocal
rem  Self-contained launcher: MSUpdate downloader DETECT + REMEDIATE.
rem  Decodes an embedded, byte-exact PowerShell script and runs it.
rem  Default (double-click / no args): scan, report, then ask before fixing.
rem  Right-click -> Run as administrator for full coverage.
rem  Args pass through:   Remediate-MSUpdate.cmd -Report
rem                       Remediate-MSUpdate.cmd -Fix
rem                       Remediate-MSUpdate.cmd -Fix -DeepScan
set "B64=%TEMP%\Remediate_MSUpdate_%RANDOM%.b64"
set "PS1=%~dp0Remediate-MSUpdate.ps1"
if exist "%B64%" del "%B64%"
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo 
>>"%B64%" echo PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PScKfQoKV3JpdGUtTG9nICcnCldyaXRlLUxvZyAiIExvZyBzYXZlZDogJExvZ1BhdGgiCg==
certutil -f -decode "%B64%" "%PS1%" >nul
del "%B64%" 2>nul
echo Decoded "%PS1%"
echo.
powershell -NoProfile -ExecutionPolicy Bypass -File "%PS1%" %*
echo.
pause
